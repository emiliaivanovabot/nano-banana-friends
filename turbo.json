{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  },
  "globalDependencies": [
    "package.json"
  ],
  "pipeline": {
    "platform#dev": {
      "command": "next dev -p 3000",
      "cache": false,
      "persistent": true
    },
    "nano-banana#dev": {
      "command": "next dev -p 3001", 
      "cache": false,
      "persistent": true
    },
    "seedream#dev": {
      "command": "next dev -p 3002",
      "cache": false, 
      "persistent": true
    }
  }
}